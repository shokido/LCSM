! Namelist of LCSM code
!
&date
dt=3600.0             ! time step in seconds
start_yymmdd=20150101 ! Start year,month,day
start_hhmmss=000000   ! Start hour,minute,second
end_yymmdd=20150131 ! End year,month,day
end_hhmmss=000000   ! End hour,minute,second
/
&grid
fname_in_grid='../PreProcessing/GRID/grid_eqpac_30.nc'
/
&taux_param_ocn
nfile_ocn_taux=1
timename_ocn_taux="time"
varname_ocn_taux="uw"
Lcycle_ocn_taux="T"
Tcycle_ocn_taux=365.0
/
&taux_io_ocn
fnames_ocn_taux(1)="../PreProcessing/WIND/jra55do_uw_clm_eqpac_30.nc"
/
&tauy_param_ocn
nfile_ocn_tauy=1
timename_ocn_tauy="time"
varname_ocn_tauy="vw"
Lcycle_ocn_tauy="T"
Tcycle_ocn_tauy=365.0
/
&tauy_io_ocn
fnames_ocn_tauy(1)="../PreProcessing/WIND/jra55do_vw_clm_eqpac_30.nc"
/
&cn_param_ocn
nfile_ocn_cn=1
timename_ocn_cn="time"
varname_ocn_cn="cn"
Lcycle_ocn_cn="T"
Tcycle_ocn_cn=365.0
/
&cn_io_ocn
fnames_ocn_cn(1)="../PreProcessing/STRF/STRF_TLLL/WOA18_strf_ann_eqpac_30_mode5.nc"
/
&obn_param_ocn
nfile_ocn_obn=1
timename_ocn_obn="time"
varname_ocn_obn="obn"
Lcycle_ocn_obn="T"
Tcycle_ocn_obn=365.0
/
&obn_io_ocn
fnames_ocn_obn(1)="../PreProcessing/STRF/STRF_TLLL/WOA18_strf_ann_eqpac_30_mode5.nc"
/
&init
in_rst_flag="F"
fname_in_rst="restart_eqpac30.nc"
/
! History file
&output_hist
out_hist_flag=1
out_hist_int=5
fname_out_hist="../OUTPUTS/hist_eqpac30_jra55do_mode5_varcp.nc"
/
! Average file
&output_avg
out_avg_flag=1
out_avg_int=5
fname_out_avg="../OUTPUTS/avg_eqpac30_jra55do_mode5_varcp.nc"
/
&output_rst
out_rst_flag="T"
fname_out_rst="../OUTPUTS/restart_eqpac30_jra55do_mode5_varcp.nc"
/
&param_ocn
oset%slip_ind=2.0
oset%nu_h=2.0e4
oset%A=2.0e-7
/
